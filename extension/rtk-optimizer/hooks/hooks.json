{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${ATTENTION_PLUGIN_ROOT}/dist/rtk-optimizer-hook.mjs"],
            "timeout": 8
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${ATTENTION_PLUGIN_ROOT}/dist/rtk-optimizer-hook.mjs"],
            "timeout": 8
          }
        ]
      }
    ]
  }
}
